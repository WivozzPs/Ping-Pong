-- AUTO BUY
local autoButton = createButton("Auto Buy")
local autoBuy = false

local function getPromptPosition(prompt)
	local parent = prompt.Parent
	if parent:IsA("BasePart") then return parent.Position end
	local model = prompt:FindFirstAncestorOfClass("Model")
	if model and model.PrimaryPart then return model.PrimaryPart.Position end
end

local function autoInteract()
	while autoBuy do
		local char = player.Character
		if char and char:FindFirstChild("HumanoidRootPart") then
			local rootPos = char.HumanoidRootPart.Position
			local closestPrompt
			local closestDistance = RADIUS
			
			for _, prompt in pairs(workspace:GetDescendants()) do
				if prompt:IsA("ProximityPrompt") and prompt.Enabled and string.lower(prompt.ActionText) == "purchase" then
					local pos = getPromptPosition(prompt)
					if pos then
						local dist = (pos - rootPos).Magnitude
						if dist <= closestDistance then
							closestDistance = dist
							closestPrompt = prompt
						end
					end
				end
			end
			
			if closestPrompt then
				fireproximityprompt(closestPrompt)
			end
		end
		task.wait(0.3)
	end
end

local function setAutoBuy(state)
	autoBuy = state
	autoButton.Text = "Auto Buy : " .. (state and "ON" or "OFF")
	autoButton.BackgroundColor3 = state and Color3.fromRGB(0,170,0) or Color3.fromRGB(120,0,0)
	if state then task.spawn(autoInteract) end
end

autoButton.MouseButton1Click:Connect(function()
	setAutoBuy(not autoBuy)
end)

